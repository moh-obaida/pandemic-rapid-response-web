{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('status').val() === 'lobby' || data.child('status').val() === 'playing')",
        ".validate": "newData.hasChildren(['status', 'players', 'gameState', 'settings', 'hostId']) && newData.child('status').isString() && newData.child('players').hasChildren()"
      },
      ".indexOn": ["status", "createdAt"]
    },
    ".read": false,
    ".write": false
  }
}
